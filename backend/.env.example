# Application
APP_NAME=Nexus LearnAI API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Security — generate strong random values for production
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# PostgreSQL (async)
DATABASE_URL=postgresql+asyncpg://nexus:nexus@localhost:5432/nexus_learnai

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Offline / edge
SQLITE_FALLBACK_URL=sqlite+aiosqlite:///./nexus_offline.db

# AI engine (optional local paths)
NEXUS_CPP_MODULE_ENABLED=false
ONNX_MODELS_PATH=../ai-models/onnx
EMBEDDINGS_DIM=384
